<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>@ViewData["Title"] - Dominic Portfolio</title>

		<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
		<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
		<link rel="stylesheet" href="~/IT_ELECTIVE_2_Midterm_A1_Billena_Dominic.styles.css" asp-append-version="true" />
	</head>

	<body>

		<div class="container-fluid">
			<div class="row">

				<!-- Sidebar -->
				<nav class="col-md-3 col-lg-2 d-md-block bg-dark text-white min-vh-100 p-3">

					<h3 class="text-center mb-4">My Portfolio</h3>

					<ul class="nav flex-column">

						<li class="nav-item mb-2">
							<a class="nav-link text-white" href="#home">
								🏠 Home
							</a>
						</li>

						<li class="nav-item mb-2">
							<a class="nav-link text-white" href="#about">
								👤 About Me
							</a>
						</li>

						<li class="nav-item mb-2">
							<a class="nav-link text-white" href="#skills">
								💻 Skills
							</a>
						</li>

						<li class="nav-item mb-2">
							<a class="nav-link text-white" href="#projects">
								📁 Projects
							</a>
						</li>

						<li class="nav-item mb-2">
							<a class="nav-link text-white" href="#contact">
								📞 Contact
							</a>
						</li>

					</ul>

				</nav>

				<!-- Main Content -->
				<main class="col-md-9 col-lg-10 p-4">

					@RenderBody()

				</main>

			</div>
		</div>

		<script src="~/lib/jquery/dist/jquery.min.js"></script>
		<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
		<script src="~/js/site.js" asp-append-version="true"></script>

		@await RenderSectionAsync("Scripts", required: false)

	</body>
</html>