<!-- HOME -->
<section id="home" class="container py-5">
    <div class="row align-items-center">

        <div class="col-lg-6">
            <h1 class="display-3 fw-bold">Dominic Billena II</h1>

            <h3 class="text-primary mb-3">
                Aspiring Software Developer
